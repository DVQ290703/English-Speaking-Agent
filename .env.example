# App
APP_ENV=development
LOG_LEVEL=INFO

# Frontend (when running vite locally set to backend dev server)
VITE_API_BASE_URL=http://localhost:8000

# Auth
JWT_SECRET_KEY=replace_with_a_strong_secret_at_least_32_characters
JWT_EXPIRE_MINUTES=60

# PostgreSQL
POSTGRES_DB=voice_agent
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace_with_a_strong_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@local.dev
PGADMIN_DEFAULT_PASSWORD=replace_with_a_strong_pgadmin_password

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace_with_a_strong_minio_root_password
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace_with_a_strong_minio_secret
MINIO_BUCKET=voice-agent-audio
MINIO_SECURE=false

# Redis (used for rate limiting when running in docker-compose)
REDIS_URL=redis://localhost:6379/0

# Guardrails
RATE_LIMIT_RPM=10
MAX_INPUT_CHARS=2000
INJECTION_USE_LLM=false
TOPIC_BLOCKLIST=[]

# Audit
AUDIT_DB_ENABLED=false

# CORS — comma-separated list of allowed origins
# docker compose: http://localhost:3000
# local vite dev: http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_VOICE_ID=your_default_elevenlabs_voice_id_here
ELEVENLABS_VOICE_ID_MALE=your_male_elevenlabs_voice_id_here
ELEVENLABS_VOICE_ID_FEMALE=your_female_elevenlabs_voice_id_here

# Azure Speech pronunciation assessment
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=your_azure_speech_region_here

# LangSmith tracing (optional)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=voice-agent

# AI Hook Logging (optional)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=your_ai_log_api_key_here
AI_LOG_SUBMIT_URL=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_SUBMIT_KEY=your_ai_log_submit_key_here
AI_LOG_DIR=.ai-log
