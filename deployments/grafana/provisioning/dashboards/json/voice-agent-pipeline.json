      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (status) (rate(llm_requests_total[$__rate_interval]))",
          "legendFormat": "{{status}}"
