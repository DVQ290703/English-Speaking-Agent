      "options": {"tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (status) (rate(llm_requests_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "title": "LLM Request Rate",
      "type": "timeseries"
    },
