{
  "version": "1.0",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "name": "log-prompt",
            "command": "python scripts/log_hook.py --tool codex",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "name": "log-stop",
            "command": "python scripts/log_hook.py --tool codex",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
