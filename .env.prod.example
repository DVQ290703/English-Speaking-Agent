# =============================================================================
# Production Environment — English Speaking Agent
# Usage:
#   kubectl create secret generic backend-secret \
#     --from-env-file=.env.prod \
#     -n english-speaking-agent
#
# Fill in every value marked CHANGE_ME before running the command above.
# Never commit this file with real secrets.
# =============================================================================

# App
APP_ENV=production
LOG_LEVEL=INFO

# Auth — generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_min_32_chars
JWT_EXPIRE_MINUTES=60

# PostgreSQL — use Cloud SQL private IP or K8s service name
POSTGRES_DB=voice_agent
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres-service.english-speaking-agent.svc.cluster.local
POSTGRES_PORT=5432

# MinIO — internal K8s service endpoint (used by backend to talk to MinIO pod)
MINIO_ENDPOINT=minio-service.english-speaking-agent.svc.cluster.local:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=voice-agent-audio
MINIO_AUDIO_BUCKET=voice-agent-audio
# Public endpoint browsers use for presigned URLs (via ingress /storage/* rule)
# These two are also set directly in deploy.yaml — kept here for local tooling
MINIO_PUBLIC_ENDPOINT=vinai-speaking-agent.duckdns.org/storage
MINIO_PUBLIC_SECURE=true
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME

# Redis — internal K8s service endpoint
REDIS_URL=redis://redis-service.english-speaking-agent.svc.cluster.local:6379/0

# CORS — only the production domain
CORS_ORIGINS=https://vinai-speaking-agent.duckdns.org

# OAuth redirect base URLs
APP_BASE_URL=https://vinai-speaking-agent.duckdns.org
FRONTEND_URL=https://vinai-speaking-agent.duckdns.org

# Guardrails
RATE_LIMIT_RPM=10
MAX_INPUT_CHARS=2000
INJECTION_USE_LLM=false
TOPIC_BLOCKLIST=[]

# Audit
AUDIT_DB_ENABLED=true

# Groq
GROQ_API_KEY=CHANGE_ME
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_STT_MODEL=whisper-large-v3-turbo

# ElevenLabs
ELEVENLABS_API_KEY=CHANGE_ME
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_VOICE_ID=CHANGE_ME
ELEVENLABS_US_MALE_VOICE_ID=CHANGE_ME
ELEVENLABS_US_FEMALE_VOICE_ID=CHANGE_ME
ELEVENLABS_UK_MALE_VOICE_ID=CHANGE_ME
ELEVENLABS_UK_FEMALE_VOICE_ID=CHANGE_ME

# Azure Speech
AZURE_SPEECH_KEY=CHANGE_ME
AZURE_SPEECH_REGION=CHANGE_ME

# OAuth — Google
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# OAuth — Microsoft
MICROSOFT_CLIENT_ID=CHANGE_ME
MICROSOFT_CLIENT_SECRET=CHANGE_ME

# OAuth — Facebook
FACEBOOK_CLIENT_ID=CHANGE_ME
FACEBOOK_CLIENT_SECRET=CHANGE_ME

# Grafana — used by grafana deploy.yaml (key: GRAFANA_ADMIN_PASSWORD)
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# Elasticsearch
ELASTICSEARCH_PASSWORD=CHANGE_ME

# LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=CHANGE_ME
LANGSMITH_PROJECT=voice-agent

