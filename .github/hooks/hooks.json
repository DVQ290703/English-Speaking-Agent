{
  "version": 1,
  "hooks": {
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "python scripts/log_hook.py --tool copilot",
        "powershell": "python scripts/log_hook.py --tool copilot",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "python scripts/log_hook.py --tool copilot",
        "powershell": "python scripts/log_hook.py --tool copilot",
        "timeoutSec": 10
      }
    ]
  }
}
